{
  "name": "nexus",
  "version": "0.1.1",
  "private": true,
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "build:data": "node scripts/compile-data.mjs",
    "build:wp": "npm run build:data && node scripts/build-wordpress-content.mjs",
    "publish:wp": "npm run build:wp && node scripts/publish-wordpress-page.mjs",
    "serve:wp": "python3 -m http.server 4173",
    "backup:rakdi": "node scripts/backup-and-publish-rakdi2.mjs",
    "build:rakdi": "node scripts/build-rakdi.mjs",
    "publish:rakdi": "npm run build:rakdi && node scripts/publish-rakdi.mjs"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.93.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "next": "15.1.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@prisma/client": "^5.22.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}